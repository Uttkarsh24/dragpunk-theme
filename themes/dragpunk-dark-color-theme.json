  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a7267",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords & Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#ffaa00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JavaScript/TypeScript Imports & Exports",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "meta.import keyword.control",
        "meta.export keyword.control"
      ],
      "settings": {
        "foreground": "#ffaa00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.method.declaration entity.name.function"
      ],
      "settings": {
        "foreground": "#38bdf8",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables & Parameters",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.declaration",
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#eef2f7"
      }
    },
    {
      "name": "Object Keys & Properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.property",
        "variable.other.object.property",
        "meta.property.object"
      ],
      "settings": {
        "foreground": "#e040fb"
      }
    },
    {
      "name": "Constants, Numbers & Booleans",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ff6b00"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#00f0ff"
      }
    },
    {
      "name": "Types, Classes & Interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.name.type.interface",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#ffaa00"
      }
    },
    {
      "name": "React JSX/HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff3366"
      }
    },
    {
      "name": "React Custom Components",
      "scope": [
        "support.class.component",
        "entity.name.tag.custom"
      ],
      "settings": {
        "foreground": "#00ff88",
        "fontStyle": "bold"
      }
    },
    {
      "name": "React JSX/HTML Attributes & Props",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff6b00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Property Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#e040fb"
      }
    },
    {
      "name": "Punctuation & Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block"
      ],
      "settings": {
        "foreground": "#d261e6"
      }
    },
    {
      "name": "RegExp",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "punctuation.definition.string.regexp"
      ],
      "settings": {
        "foreground": "#e040fb"
      }
    },
    {
      "name": "Markdown Titles",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#ffaa00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Links & Inline Code",
      "scope": [
        "markup.underline.link",
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#00ff88"
      }
    },
    {
      "name": "CSS Property Names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media"
      ],
      "settings": {
        "foreground": "#e040fb"
      }
    },
    {
      "name": "CSS Class Names",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#00ff88",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Values & Units",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#ff6b00"
      }
    }
  ]
}
