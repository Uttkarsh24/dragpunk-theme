  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7c776b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords & Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "variable.language.this",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    {
      "name": "JavaScript/TypeScript Imports & Exports",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "meta.import keyword.control",
        "meta.export keyword.control"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.method.declaration entity.name.function"
      ],
      "settings": {
        "foreground": "#1d4ed8",
        "fontStyle": ""
      }
    },
    {
      "name": "Variables & Parameters",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.other.declaration",
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#26231e"
      }
    },
    {
      "name": "Object Keys & Properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "variable.other.property",
        "variable.other.object.property",
        "meta.property.object"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "Constants, Numbers & Booleans",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c2410c"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#0891b2"
      }
    },
    {
      "name": "Types, Classes & Interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.name.type.interface",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#b45309"
      }
    },
    {
      "name": "React JSX/HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#b91c1c"
      }
    },
    {
      "name": "React Custom Components",
      "scope": [
        "support.class.component",
        "entity.name.tag.custom"
      ],
      "settings": {
        "foreground": "#047857",
        "fontStyle": "bold"
      }
    },
    {
      "name": "React JSX/HTML Attributes & Props",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c2410c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Property Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "Punctuation & Operators",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.block"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "RegExp",
      "scope": [
        "string.regexp",
        "constant.other.character-class.regexp",
        "punctuation.definition.string.regexp"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "Markdown Titles",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#b45309",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Links & Inline Code",
      "scope": [
        "markup.underline.link",
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#047857"
      }
    },
    {
      "name": "CSS Property Names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media"
      ],
      "settings": {
        "foreground": "#7c3aed"
      }
    },
    {
      "name": "CSS Class Names",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#047857",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Values & Units",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#c2410c"
      }
    }
  ]
}
